{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "target": "ES2020",
        "lib": ["ES2020", "DOM", "DOM.Iterable"],
        "moduleResolution": "bundler",
        "module": "ESNext",
        "noFallthroughCasesInSwitch": true,
        "composite": true,
        "declaration": true,
        "outDir": "dist/",
        "rootDir": "src",
        "paths": {
            "@/*": ["./src/*"]
        },
        "noUnusedLocals": false,
        "noUnusedParameters": false
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
